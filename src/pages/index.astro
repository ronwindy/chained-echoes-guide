---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Welcome">
  <div class="hero">
    <h1>Chained Echoes</h1>
    <p class="subtitle">An Interactive Walkthrough</p>
  </div>

  <section class="content-section" id="intro">
    <h2>Welcome to Valandis</h2>
    <p>This is a custom-built, interactive guide for Chained Echoes. It features a responsive layout, beautiful aesthetics inspired by the game, and an easy-to-navigate Table of Contents on the left.</p>
    <p>Later, we will extract actual guide content and populate these sections!</p>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
  }

  .hero h1 {
    font-size: 4rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    font-family: var(--font-heading);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .content-section {
    margin-bottom: 3rem;
  }

  .content-section h2 {
    font-size: 2rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }
</style>
