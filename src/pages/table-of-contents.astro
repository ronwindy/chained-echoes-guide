<style>
  .toc-header {
    text-align: center;
    margin-top: 2rem;
    margin-bottom: 4rem;
    padding: 0 1rem;
  }

  .toc-header h1 {
    font-size: clamp(1.8rem, 10vw, 3.5rem); /* Scaled down for mobile */
    color: var(--accent-gold);
    margin-bottom: 1.25rem; /* More space for subtitle */
    line-height: 1.2;
    text-shadow: 0 4px 10px rgba(0, 0, 0, 0.8);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .subtitle {
    font-size: clamp(0.8rem, 5vw, 1.1rem); /* Much smaller for mobile */
    color: var(--text-muted);
    font-family: var(--font-heading);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.9;
    display: block; /* Ensure it stays below */
    max-width: 90%;
    margin: 0 auto;
  }

/* Grid Settings */
  .toc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 2.5rem;
    align-items: start;
  }

  /* Responsive Grid Tweaks */
  @media (max-width: 600px) {
    .toc-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

 .toc-card {
    background: linear-gradient(145deg, var(--bg-card), rgba(21, 24, 33, 0.9));
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 0;
    position: relative;
    overflow: hidden;
    transition:
      box-shadow 0.3s ease,
      border-color 0.3s ease;
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    min-height: 110px;
  }

  .toc-card-toggle {
    background: none;
    border: none;
    cursor: pointer;
    width: 100%;
    padding: 1.5rem 1.8rem;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-height: 110px;
    flex-shrink: 0;
  }

  .toggle-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--accent-blue);
    transition: transform 0.3s ease;
  }

  .toc-card-toggle[aria-expanded="true"] .toggle-icon {
    transform: rotate(180deg);
  }

  .toc-card-toggle h2 {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .toc-card-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
  }

.toc-card-toggle[aria-expanded="true"] + .toc-card-content {
    max-height: 2000px;
    transition: max-height 0.5s ease-in;
    padding: 0 2.2rem 2.2rem 2.2rem;
    margin-top: 0;
  }

  .toc-card ul {
    margin-top: 0;
  }

  .toc-card h3 {
    margin-top: 2rem;
  }

  .toc-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(to bottom, var(--accent-gold), transparent);
    opacity: 0.6;
  }

.toc-card:hover {
    box-shadow:
      0 12px 30px rgba(0, 0, 0, 0.5),
      0 0 20px var(--accent-glow);
    border-color: var(--accent-blue);
  }

  .toc-card-toggle[aria-expanded="true"] h2 {
    color: var(--accent-blue);
  }

  .toc-card-toggle[aria-expanded="true"] .title-icon {
    color: var(--accent-blue);
    filter: drop-shadow(0 0 8px var(--accent-blue));
  }

  .toc-card h2 {
    color: var(--accent-gold);
    margin-bottom: 0;
    font-size: clamp(1.2rem, 3.2vw, 1.45rem);
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .title-icon {
    width: 26px;
    height: 26px;
    flex-shrink: 0;
    color: var(--accent-gold);
    filter: drop-shadow(0 0 5px rgba(226, 180, 59, 0.4));
    transition:
      transform 0.3s ease,
      filter 0.3s ease;
  }

  .toc-card:hover .title-icon {
    transform: scale(1.1) rotate(5deg);
    filter: drop-shadow(0 0 8px var(--accent-blue));
    color: var(--accent-blue);
  }

  .toc-card h3 {
    color: var(--accent-blue);
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.4rem; /* Matching the user's "comfortable" size for subheaders */
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
  }

  .toc-card h3::before {
    content: "◈";
    margin-right: 0.75rem;
    font-size: 0.9rem;
    color: var(--accent-gold);
  }

  .toc-card ul {
    list-style: none;
    margin-left: 0.2rem;
  }

  .toc-card li {
    margin-bottom: 0.8rem;
    position: relative;
    padding-left: 2rem;
  }

  .toc-card li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent-blue);
    font-size: 1.2rem; /* Larger arrow for larger text */
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.5;
    transition:
      opacity 0.2s,
      transform 0.2s;
  }

  .toc-card li:hover::before {
    opacity: 1;
    transform: translateY(-50%) translateX(5px);
  }

  .toc-card a {
    color: var(--text-main);
    /* Removed font-size override: now uses the global comfy 1.4rem+ */
    transition:
      color 0.2s,
      background-color 0.2s;
    display: block;
    padding: 0.2rem 0;
  }

  .toc-card a:hover {
    color: var(--accent-gold);
    text-decoration: none;
  }

  /* Completed guide indicator */
  .toc-card a.completed {
    color: var(--accent-gold);
    position: relative;
  }

  .toc-card a.completed::after {
    content: "✓";
    position: absolute;
    right: 0;
    color: var(--accent-gold);
    font-weight: bold;
  }

  /* DLC link-out card */
  .toc-card--dlc {
    background: linear-gradient(
      145deg,
      rgba(10, 40, 35, 0.6),
      rgba(21, 24, 33, 0.9)
    );
    border-color: rgba(45, 212, 191, 0.3);
    padding: 1.5rem 1.8rem;
    position: relative;
    overflow: hidden;
    transition:
      box-shadow 0.3s ease,
      border-color 0.3s ease;
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    min-height: 110px;
  }

  .toc-card--dlc::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(to bottom, #2dd4bf, transparent);
    opacity: 0.8;
  }

  .toc-card--dlc:hover {
    border-color: rgba(45, 212, 191, 0.7);
    box-shadow:
      0 12px 30px rgba(0, 0, 0, 0.5),
      0 0 20px rgba(45, 212, 191, 0.25);
  }

  .dlc-card-description {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  .dlc-cta-button {
    display: inline-block;
    box-sizing: border-box;
    padding: 1rem 1.5rem !important;
    background: linear-gradient(
      135deg,
      rgba(45, 212, 191, 0.2),
      rgba(10, 80, 70, 0.3)
    );
    border: 1px solid rgba(45, 212, 191, 0.4);
    border-radius: 8px;
    color: #5eead4;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease,
      transform 0.2s ease;
  }

  .dlc-cta-button:hover {
    background: linear-gradient(
      135deg,
      rgba(45, 212, 191, 0.35),
      rgba(10, 80, 70, 0.45)
    );
    border-color: rgba(45, 212, 191, 0.7);
    color: #b8f9f1;
    transform: translateX(4px);
    text-decoration: none;
  }
</style>

<script>
  // Update table of contents to show completed guides
  const getCompletedGuides = (): string[] => {
    const stored = localStorage.getItem("chained-echoes-completed");
    return stored ? JSON.parse(stored) : [];
  };

  // Map guide IDs to their href patterns in the TOC
  const guideIdMap: Record<string, string> = {
    "three-months-later": "three-months-later",
    "world-exploration": "world-exploration",
    "search-for-princess": "search-for-princess",
    "looking-for-allies": "looking-for-allies",
    "storming-tormund": "storming-tormund",
    "mysterious-girl-2": "mysterious-girl-2",
    "world-exploration-2": "world-exploration-2",
    "a-call-from-the-past": "a-call-from-the-past",
    "ruins-under-a-tree": "ruins-under-a-tree",
    "the-food-the-chap-and-the-hungry": "the-food-the-chap-and-the-hungry",
    "killing-gods": "killing-gods",
    "eastern-ograne-grottos": "eastern-ograne-grottos",
    "a-little-vacation": "a-little-vacation",
    "the-gates-of-nhysa": "the-gates-of-nhysa",
    "into-the-maelstrom": "into-the-maelstrom",
    "for-the-love-of-food": "for-the-love-of-food",
    "a-goblins-dilemma": "a-goblins-dilemma",
    "two-winged-angel": "two-winged-angel",
    "falfalaran-sings-the-fairy": "falfalaran-sings-the-fairy",
    "a-will-to-live": "a-will-to-live",
    "no-place-for-happy-endings": "no-place-for-happy-endings",
  };

  // Update TOC links with completed status
  const updateTOCLinks = () => {
    const completedGuides = getCompletedGuides();
    const tocLinks = document.querySelectorAll(".toc-card a");
    tocLinks.forEach((link) => {
      const href = link.getAttribute("href") || "";
      const guideId = Object.keys(guideIdMap).find((id) => href.includes(id));
      if (guideId && completedGuides.includes(guideId)) {
        link.classList.add("completed");
      } else {
        link.classList.remove("completed");
      }
    });
  };

// Expose function for toggleCompletion to call
  (window as any).updateCompletedIndicators = updateTOCLinks;

  // Collapsible cards functionality
  const initCollapsibleCards = () => {
    const toggles = document.querySelectorAll(".toc-card-toggle");

    toggles.forEach((toggle) => {
      toggle.addEventListener("click", (e) => {
        e.stopPropagation();
        const isExpanded = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!isExpanded));
      });
    });
  };

  // Wait for DOM to be ready
  if (typeof document !== "undefined") {
    initCollapsibleCards();
    updateTOCLinks();
  }
</script>
