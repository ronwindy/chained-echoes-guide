      </button>
      <div class="toc-card-content">
        <ul>
          <li><a href="#">Prologue</a></li>
          <li><a href="#">Act 1</a></li>
          <li><a href="#">Act 2</a></li>
          <li><a href="#">Act 3</a></li>
          <li><a href="#">Act 4</a></li>
        </ul>
      </div>
    </section>

<!-- Reward Board -->
    <section class="toc-card">
      <button class="toc-card-toggle" aria-expanded="false">
        <h2>
          <svg class="toggle-icon" viewBox="0 0 24 24">
            <path fill="currentColor" d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
          </svg>
          <svg viewBox="0 0 24 24" class="title-icon"
            ><path
              fill="currentColor"
              d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2m0 18H6V4h12v16M8 15h8v2H8v-2m0-4h8v2H8v-2m0-4h8v2H8V7Z"
            ></path></svg
