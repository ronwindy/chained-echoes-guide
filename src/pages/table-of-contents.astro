---
import Layout from "../layouts/Layout.astro";
const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="Table of Contents">
  <div class="toc-header">
    <h1>Table of Contents</h1>
    <p class="subtitle">Complete Guide to Chained Echoes</p>
  </div>

 <div class="toc-grid">
    <!-- Getting Started -->
    <section class="toc-card">
      <button class="toc-card-toggle" aria-expanded="false">
        <h2>
          <svg class="toggle-icon" viewBox="0 0 24 24">
            <path fill="currentColor" d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
          </svg>
          <svg viewBox="0 0 24 24" class="title-icon"
            ><path
              fill="currentColor"
              d="M19 2H5c-1.11 0-2 .89-2 2v16c0 1.11.89 2 2 2h14c1.11 0 2-.89 2-2V4c0-1.11-.89-2-2-2m-1 18H6V4h12v16m-2-10h-2V6h2v4m0 4h-2v-2h2v2m0 4h-2v-2h2v2Z"
            ></path></svg
          >
          Getting Started
        </h2>
      </button>
      <div class="toc-card-content">
        <ul>
          <li><a href={baseUrl}>Controls</a></li>
          <li><a href=`${baseUrl}table-of-contents`>Table of Contents</a></li>
        </ul>
      </div>
    </section>

   <!-- Walkthrough -->
    <section class="toc-card">
      <button class="toc-card-toggle" aria-expanded="false">
        <h2>
          <svg class="toggle-icon" viewBox="0 0 24 24">
            <path fill="currentColor" d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
          </svg>
          <svg viewBox="0 0 24 24" class="title-icon"
            ><path
              fill="currentColor"
              d="M21 16.5c0 .38-.21.71-.53.88l-7.97 4.43c-.16.09-.33.14-.5.14-.5-.14-.5-.14-.5-.14s-.34-.05-.5-.14l-7.97-4.43c-.32-.17-.53-.5-.53-.88v-9c0-.38.21-.71.53-.88l7.97-4.43c.16-.09-.33-.14-.5-.14s.34.05-.5.14l7.97 4.43c.32.17-.53.5.53.88v9M12 4.15L6.04 7.47v6.66L12 17.45l5.96-3.32V7.47L12 4.15Z"
            ></path></svg
          >
          Walkthrough
        </h2>
      </button>
      <div class="toc-card-content">
        <h3>Act 2</h3>
        <ul>
          <li>
            <a href=`${baseUrl}walkthrough/three-months-later`
              >Three Months Later</a
            >
          </li>
          <li>
            <a href=`${baseUrl}walkthrough/world-exploration`>World Exploration</a
            >
          </li>
          <li>
            <a href=`${baseUrl}walkthrough/search-for-princess`
              >Searching for a Princess</a
            >
          </li>
          <li>
            <a href=`${baseUrl}walkthrough/looking-for-allies`
              >Looking for Allies</a
            >
          </li>
          <li>
            <a href=`${baseUrl}walkthrough/storming-tormund`>Storming Tormund</a>
          </li>
          <li>
            <a href=`${baseUrl}walkthrough/mysterious-girl-2`>Mysterious Girl 2</a
            >
          </li>
        </ul>

        <h3>Act 3</h3>
        <ul>
          <li>
            <a href={`${baseUrl}walkthrough/a-call-from-the-past`}
              >A Call From the Past</a
            >
