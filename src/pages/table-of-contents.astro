 <!-- Boss Fights -->
    <section class="toc-card">
      <button class="toc-card-toggle" aria-expanded="false">
        <h2>
          <svg class="toggle-icon" viewBox="0 0 24 24">
            <path fill="currentColor" d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
          </svg>
          <svg viewBox="0 0 24 24" class="title-icon"
            ><path
              fill="currentColor"
              d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10s10-4.47 10-10S17.53 2 12 2m0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8s8 3.59 8 8s-3.59 8-8 8m-4-7h2.5l-1.5 3l4.5-4h-2.5l1.5-3l-4.5 4Z"
            ></path></svg
