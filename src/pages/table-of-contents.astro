    <!-- Ashes of Elrant DLC (link-out card) -->
    <section class="toc-card toc-card--dlc">
      <h2>
        <svg viewBox="0 0 24 24" class="title-icon"
          ><path
            fill="currentColor"
            d="M11 21h-1l1-7H7.5c-.83 0-1.5-.67-1.5-1.5c0-.44.18-.83.48-1.12L13 2h1l-1 7h3.5c.83 0 1.5.67 1.5 1.5c0 .44-.18.83-.48 1.12L11 21Z"
          ></path></svg
