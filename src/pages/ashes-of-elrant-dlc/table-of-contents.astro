---
import DlcLayout from "../../layouts/DlcLayout.astro";
const baseUrl = import.meta.env.BASE_URL;
---

<DlcLayout title="">
  <div class="toc-header">
    <img
      src=`${baseUrl}logo-dlc.png`
      alt="Chained Echoes: Ashes of Elrant"
      class="toc-logo"
    />
  </div>

<div class="toc-grid">
    <!-- Introduction -->
    <section class="toc-card">
      <button class="toc-card-toggle" aria-expanded="false">
        <h2>
          <svg class="toggle-icon" viewBox="0 0 24 24">
            <path fill="currentColor" d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
          </svg>
          <svg viewBox="0 0 24 24" class="title-icon"
            ><path
              fill="currentColor"
              d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
            ></path></svg
          >
          <span>Introduction</span>
        </h2>
      </button>
      <div class="toc-card-content">
        <ul>
          <li>
            <a href={`${baseUrl}ashes-of-elrant-dlc/ashes-of-elrant-introduction`}
              >Introduction</a
            >
          </li>
        </ul>
      </div>
    </section>

  <!-- Walkthrough -->
    <section class="toc-card">
      <button class="toc-card-toggle" aria-expanded="false">
        <h2>
          <svg class="toggle-icon" viewBox="0 0 24 24">
            <path fill="currentColor" d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
          </svg>
          <svg viewBox="0 0 24 24" class="title-icon"
            ><path
              fill="currentColor"
              d="M21 16.5c0 .38-.21.71-.53.88l-7.97 4.43c-.16.09-.33.14-.5.14-.5-.14-.5-.14-.5-.14s-.34-.05-.5-.14l-7.97-4.43c-.32-.17-.53-.5-.53-.88v-9c0-.38.21-.71.53-.88l7.97-4.43c.16-.09-.33-.14-.5-.14s.34.05-.5.14l7.97 4.43c.32.17-.53.5.53.88v9M12 4.15L6.04 7.47v6.66L12 17.45l5.96-3.32V7.47L12 4.15Z"
            ></path></svg
          >
          <span>Walkthrough</span>
        </h2>
      </button>
      <div class="toc-card-content">
        <ul>
          <li>
            <a href={`${baseUrl}ashes-of-elrant-dlc/into-the-unknown`}
              >Into the Unknown</a
            >
          </li>
          <li>
            <a href={`${baseUrl}ashes-of-elrant-dlc/beyond-the-rift`}
              >Beyond the Rift</a
            >
          </li>
          <li>
            <a href={`${baseUrl}ashes-of-elrant-dlc/the-big-escape`}
              >The Big Escape</a
            >
          </li>
          <li>
            <a href={`${baseUrl}ashes-of-elrant-dlc/the-truth-of-elerant`}
              >The Truth of Elrant</a
            >
          </li>
          <li>
            <a href={`${baseUrl}ashes-of-elrant-dlc/the-open-way`}>The Open Way</a
            >
            <ul class="child-list">
              <li>
                <a href={`${baseUrl}ashes-of-elrant-dlc/deadlands`}>Deadlands</a>
              </li>
              <li>
                <a href={`${baseUrl}ashes-of-elrant-dlc/world-exploration`}
                  >World Exploration</a
                >
              </li>
              <li>
                <a href={`${baseUrl}ashes-of-elrant-dlc/wastelands`}>Wastelands</a
              >
              </li>
            </ul>
          </li>
          <li>
            <a href={`${baseUrl}ashes-of-elrant-dlc/world-exploration-2`}
              >Final World Exploration</a
            >
          </li>
          <li>
            <a href={`${baseUrl}ashes-of-elrant-dlc/deus-ex-machina`}
              >Deus Ex Machina</a
            >
          </li>
        </ul>
      </div>
    </section>

<!-- Sidequest -->
    <section class="toc-card">
      <button class="toc-card-toggle" aria-expanded="false">
        <h2>
          <svg class="toggle-icon" viewBox="0 0 24 24">
            <path fill="currentColor" d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
          </svg>
          <svg viewBox="0 0 24 24" class="title-icon"
            ><path
              fill="currentColor"
              d="M18 15v3H6v-3H4v3c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2v-3h-2m-1-4l-1.41-1.41L13 12.17V4h-2v8.17L8.41 9.59L7 11l5 5 5-5Z"
            ></path></svg
          >
          <span>Sidequest</span>
        </h2>
      </button>
      <div class="toc-card-content">
        <ul>
          <li>
            <a href={`${baseUrl}ashes-of-elrant-dlc/a-second-option`}
              >A Second Option</a
            >
          </li>
        </ul>
      </div>
    </section>

<!-- Reward Board -->
    <section class="toc-card">
      <button class="toc-card-toggle" aria-expanded="false">
        <h2>
          <svg class="toggle-icon" viewBox="0 0 24 24">
            <path fill="currentColor" d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
          </svg>
          <svg viewBox="0 0 24 24" class="title-icon"
            ><path
              fill="currentColor"
              d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2m0 18H6V4h12v16M8 15h8v2H8v-2m0-4h8v2H8v-2m0-4h8v2H8V7Z"
            ></path></svg
          >
          <span>Reward Board</span>
        </h2>
      </button>
      <div class="toc-card-content">
        <ul>
          <li><a href="#">Mushroom Forest</a></li>
          <li><a href="#">Elrant City</a></li>
          <li><a href="#">Lost Gardens</a></li>
          <li><a href="#">Deadlands</a></li>
          <li><a href="#">Wastelands</a></li>
          <li><a href="#">Old Town</a></li>
        </ul>
      </div>
    </section>

<!-- Guides -->
    <section class="toc-card">
      <button class="toc-card-toggle" aria-expanded="false">
        <h2>
          <svg class="toggle-icon" viewBox="0 0 24 24">
            <path fill="currentColor" d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
          </svg>
          <svg viewBox="0 0 24 24" class="title-icon"
            ><path
              fill="currentColor"
              d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2L9.19 8.63L2 9.24l5.46 4.73L5.82 21L12 17.27Z"
            ></path></svg
          >
          <span>Guides</span>
        </h2>
      </button>
      <div class="toc-card-content">
        <ul>
          <li><a href="#">All DLC Class Emblems</a></li>
          <li><a href="#">All DLC Collectibles</a></li>
          <li><a href="#">All Flesh of Farnese Locations</a></li>
        </ul>
      </div>
    </section>
  </div>
</DlcLayout>

<style>
  .toc-header {
    text-align: center;
    margin-top: 2rem;
    margin-bottom: 4rem;
    padding: 0 1rem;
  }

  .toc-logo {
    display: block;
    margin: 0 auto 1.5rem;
    width: 100%;
    max-width: 40rem;
    height: auto;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.7));
  }

  .toc-header h1 {
    font-size: clamp(1.8rem, 10vw, 3.5rem);
    color: var(--accent-gold);
    margin-bottom: 1.25rem;
    line-height: 1.2;
    text-shadow: 0 4px 10px rgba(0, 0, 0, 0.8);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .subtitle {
    font-size: clamp(0.8rem, 5vw, 1.1rem);
    color: var(--text-muted);
    font-family: var(--font-heading);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.9;
    display: block;
    max-width: 90%;
    margin: 0 auto;
  }

/* Grid Settings */
  .toc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .toc-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

.toc-card {
    background: linear-gradient(145deg, rgba(10, 40, 35, 0.7), rgba(15, 25, 23, 0.95));
    border: 1px solid rgba(45, 212, 191, 0.15); /* Teal-tinted glass effect */
    border-top: 1px solid rgba(45, 212, 191, 0.25); /* Top highlight */
    border-radius: 12px;
    padding: 0;
    position: relative;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease, border-color 0.4s ease;
    backdrop-filter: blur(12px);
    display: flex;
    flex-direction: column;
    min-height: 110px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  .toc-card:has(.toc-card-toggle[aria-expanded="true"]) {
    border-color: rgba(45, 212, 191, 0.5);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.6), 0 0 30px rgba(45, 212, 191, 0.2);
  }

  .toc-card-toggle {
    background: transparent;
    border: none;
    cursor: pointer;
    width: 100%;
    padding: 1.5rem 2rem;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-height: 110px;
    flex-shrink: 0;
    position: relative;
    z-index: 3;
    transition: background 0.4s ease;
  }

  .toc-card-toggle:hover {
    background: linear-gradient(90deg, rgba(45, 212, 191, 0.08) 0%, transparent 100%);
  }

  .toggle-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--dlc-accent, #2dd4bf);
    transition: transform 0.3s ease;
  }

  .toc-card-toggle[aria-expanded="true"] .toggle-icon {
    transform: rotate(180deg);
  }

  .toc-card-toggle h2 {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .toc-card-content {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease, padding 0.4s ease;
  }

.toc-card-toggle[aria-expanded="true"] + .toc-card-content {
    max-height: 4000px;
    opacity: 1;
    transition: max-height 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease 0.1s;
    padding: 0.5rem 2.2rem 2.8rem 2.2rem;
    margin-top: 0;
  }

  .toc-card ul {
    margin-top: 0;
  }

  .toc-card h3 {
    margin-top: 2rem;
  }

  .toc-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(to bottom, #2dd4bf 0%, rgba(45, 212, 191, 0.2) 60%, transparent 100%);
    box-shadow: 2px 0 10px rgba(45, 212, 191, 0.5);
    z-index: 4;
    transition: opacity 0.4s ease, background 0.4s ease, box-shadow 0.4s ease;
  }

.toc-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.7), 0 0 25px rgba(45, 212, 191, 0.2);
    border-color: rgba(45, 212, 191, 0.4);
  }

  .toc-card-toggle[aria-expanded="true"] h2 {
    color: #fff;
    text-shadow: 0 0 10px rgba(45, 212, 191, 0.5);
  }

  .toc-card-toggle[aria-expanded="true"] .title-icon {
    color: #2dd4bf;
    filter: drop-shadow(0 0 10px rgba(45, 212, 191, 0.8));
  }

  .toc-card h2 {
    color: var(--accent-gold);
    margin-bottom: 0;
    font-size: clamp(1.2rem, 3.2vw, 1.45rem);
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-transform: uppercase;
  }

  .toc-card h2 span {
    white-space: nowrap;
  }

  .title-icon {
    width: 26px;
    height: 26px;
    flex-shrink: 0;
    color: var(--accent-gold);
    filter: drop-shadow(0 0 5px rgba(226, 180, 59, 0.5));
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.4s ease, color 0.4s ease;
  }

  .toc-card:hover .title-icon {
    transform: scale(1.15) rotate(8deg);
    filter: drop-shadow(0 0 12px rgba(45, 212, 191, 0.8));
    color: #2dd4bf;
  }

  .toc-card ul {
    list-style: none;
    margin-left: 0.2rem;
  }

  .toc-card li {
    margin-bottom: 0.8rem;
    position: relative;
    padding-left: 2rem;
  }

  .toc-card li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: #2dd4bf;
    font-size: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.4;
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .toc-card li:hover::before {
    opacity: 1;
    transform: translateY(-50%) translateX(5px);
  }

  .toc-card a {
    color: #ccfbf1; /* Muted teal/cyan */
    transition: color 0.3s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: inline-block;
    padding: 0.2rem 0;
  }

  .toc-card a:hover {
    color: #fff;
    text-decoration: none;
    transform: translateX(4px);
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.2);
  }

  /* Completed guide indicator */
  .toc-card a.completed {
    color: #5eead4; /* Bright teal for completed */
    font-weight: bold;
    position: relative;
  }

  .toc-card a.completed::after {
    content: "✓";
    position: absolute;
    right: -25px;
    color: #5eead4;
    font-weight: bold;
    filter: drop-shadow(0 0 4px rgba(45, 212, 191, 0.5));
  }

  /* Child list nested under a parent guide item */
  .child-list {
    list-style: none;
    margin: 0.4rem 0 0.2rem 1.25rem;
    padding-left: 0.75rem;
    border-left: 2px solid var(--border-color);
  }

  .child-list li {
    margin-bottom: 0.5rem;
    padding-left: 0;
  }

  .child-list li::before {
    content: none;
  }

  .child-list a {
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .child-list a:hover {
    opacity: 1;
  }
</style>

<script>
  // Update table of contents to show completed DLC guides
  const getCompletedGuides = (): string[] => {
    const stored = localStorage.getItem("chained-echoes-dlc-completed");
    return stored ? JSON.parse(stored) : [];
  };

  // Map DLC guide IDs to their href patterns in the TOC
  const guideIdMap: Record<string, string> = {
    "dlc-introduction": "introduction",
    "dlc-into-the-unknown": "into-the-unknown",
    "dlc-beyond-the-rift": "beyond-the-rift",
    "dlc-the-big-escape": "the-big-escape",
    "dlc-the-truth-of-elrant": "the-truth-of-elrant",
    "dlc-the-open-way": "the-open-way",
    "dlc-deadlands": "deadlands",
    "dlc-world-exploration": "world-exploration",
    "dlc-wastelands": "wastelands",
    "dlc-world-exploration-2": "world-exploration-2",
    "dlc-deus-ex-machina": "deus-ex-machina",
    "dlc-a-second-option": "a-second-option",
  };

  // Update TOC links with completed status
  const updateTOCLinks = () => {
    const completedGuides = getCompletedGuides();
    const tocLinks = document.querySelectorAll(".toc-card a");
    tocLinks.forEach((link) => {
      const href = link.getAttribute("href") || "";
      const guideId = Object.keys(guideIdMap).find((id) =>
        href.includes(guideIdMap[id]),
      );
      if (guideId && completedGuides.includes(guideId)) {
        link.classList.add("completed");
      } else {
        link.classList.remove("completed");
      }
    });
  };

(window as any).updateCompletedIndicators = updateTOCLinks;

  // Collapsible cards functionality
  const initCollapsibleCards = () => {
    const toggles = document.querySelectorAll(".toc-card-toggle");

    toggles.forEach((toggle) => {
      toggle.addEventListener("click", (e) => {
        e.stopPropagation();
        const isExpanded = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!isExpanded));
      });
    });
  };

  if (typeof document !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      updateTOCLinks();
      initCollapsibleCards();
    });
  }
</script>
