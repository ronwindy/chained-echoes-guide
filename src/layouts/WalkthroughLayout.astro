---
import Layout from "./Layout.astro";
import GuideProgress from "../components/GuideProgress.astro";

interface Section {
  id: string;
  label: string;
  subsections?: { id: string; label: string }[];
}

interface Props {
  title: string;
  subtitle?: string;
  sections: Section[];
  guideId?: string;
}

const { title, subtitle, sections, guideId } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<Layout title={title}>
  <div class="walkthrough-layout">
    <div class="walkthrough-main">
      <header class="walkthrough-header">
        <h1>{title}</h1>
        {subtitle && <p class="subtitle">{subtitle}</p>}
        {
          guideId && (
            <div class="complete-btn-container">
              <GuideProgress guideId={guideId} guideTitle={title} />
            </div>
          )
        }
      </header>

      <div class="walkthrough-content">
        <slot />
      </div>
    </div>

    <aside class="local-toc" id="local-toc">
      <div class="toc-wrapper">
        <h3>Navigation</h3>
        <nav>
          <ul>
            {
              sections.map((section) => (
                <li>
                  <a href={`#${section.id}`}>{section.label}</a>
                  {section.subsections && section.subsections.length > 0 && (
                    <ul>
                      {section.subsections.map((sub) => (
                        <li>
                          <a href={`#${sub.id}`}>{sub.label}</a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </aside>
  </div>

  <!-- Image Lightbox Overlay -->
  <div id="image-lightbox" class="lightbox">
    <span class="lightbox-close">&times;</span>
    <img id="lightbox-img" class="lightbox-content" />
  </div>
</Layout>

<style>
  .walkthrough-layout {
    display: flex;
    gap: 3rem;
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
  }

  .walkthrough-main {
    flex: 1;
    min-width: 0; /* Prevent flex blowup */
  }

  .walkthrough-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .walkthrough-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--accent-gold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--accent-blue);
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .complete-btn-container {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
  }

  /* Local TOC Sidebar */
  .local-toc {
    width: 280px;
    flex-shrink: 0;
  }

  .toc-wrapper {
    position: sticky;
    top: 2rem;
    background: linear-gradient(145deg, var(--bg-card), rgba(21, 24, 33, 0.9));
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    backdrop-filter: blur(8px);
  }

  .local-toc h3 {
    font-size: 1.1rem;
    color: var(--accent-gold);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .local-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .local-toc li {
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .local-toc a {
    color: var(--text-muted);
    text-decoration: none;
    transition:
      color 0.2s,
      padding-left 0.2s;
    display: block;
    line-height: 1.4;
  }

  .local-toc a:hover {
    color: var(--accent-blue);
    padding-left: 5px;
  }

  .local-toc ul ul {
    margin-top: 0.4rem;
    margin-left: 1rem;
    border-left: 1px solid var(--border-color);
    padding-left: 0.75rem;
  }

  .local-toc ul ul li {
    font-size: 0.85rem;
    margin-bottom: 0.3rem;
  }

  /* Responsive Design */
  @media (max-width: 1200px) {
    .local-toc {
      display: none; /* Hide on smaller screens or implement a drawer */
    }
  }

  @media (max-width: 768px) {
    .walkthrough-layout {
      flex-direction: column;
      gap: 0;
    }
  }

  /* Lightbox Styles */
  .walkthrough-content img {
    cursor: zoom-in;
  }

  .lightbox {
    display: none;
    position: fixed;
    z-index: 1000;
    padding-top: 60px;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    background-color: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(5px);
  }

  .lightbox.active {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 0;
  }

  .lightbox-content {
    margin: auto;
    display: block;
    max-width: 90%;
    max-height: 80vh;
    border: 2px solid var(--accent-gold);
    border-radius: 8px;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.8);
    animation: zoom 0.3s ease;
  }

  @keyframes zoom {
    from {
      transform: scale(0.8);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .lightbox-close {
    position: absolute;
    top: 25px;
    right: 35px;
    color: #f1f1f1;
    font-size: 40px;
    font-weight: bold;
    cursor: pointer;
    transition: color 0.2s;
    z-index: 1001;
  }

  .lightbox-close:hover,
  .lightbox-close:focus {
    color: var(--accent-gold);
    text-decoration: none;
  }
</style>

<script>
  // Simple active link observer
  const observerOptions = {
    root: null,
    rootMargin: "0px 0px -80% 0px",
    threshold: 0,
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute("id");
        const tocLinks = document.querySelectorAll(".local-toc a");
        tocLinks.forEach((link) => {
          const htmlLink = link as HTMLElement;
          htmlLink.classList.remove("active");
          if (htmlLink.getAttribute("href") === `#${id}`) {
            htmlLink.classList.add("active");
            htmlLink.style.color = "var(--accent-gold)";
          } else {
            htmlLink.style.color = "";
          }
        });
      }
    });
  }, observerOptions);

  // Track all sections and quest steps
  const sections = document.querySelectorAll("section[id], article[id]");
  if (sections) {
    sections.forEach((section) => {
      observer.observe(section);
    });
  }

  // Lightbox functionality
  const lightbox = document.getElementById("image-lightbox");
  const lightboxImg = document.getElementById("lightbox-img");
  const closeBtn = document.querySelector(".lightbox-close");

  if (lightbox && lightboxImg && closeBtn) {
    document.querySelectorAll(".walkthrough-content img").forEach((img) => {
      const parentLink = img.closest("a");
      if (parentLink) {
        parentLink.addEventListener("click", (e) => e.preventDefault());
      }

      img.addEventListener("click", () => {
        const originalSrc = img.getAttribute("src") || "";
        // Transform the thumbnail URL to the high-res URL
        // Example: https://cdn.staticneo.com/ew/thumb/1/19/Ce_427.jpg/326px-Ce_427.jpg
        // Becomes: https://cdn.staticneo.com/ew/1/19/Ce_427.jpg
        const fullSrc = originalSrc
          .replace("/thumb/", "/")
          .replace(/\/\d+px-[^\/]+$/, "");

        lightboxImg.setAttribute("src", fullSrc);
        lightbox.classList.add("active");
        document.body.style.overflow = "hidden"; // Prevent scrolling
      });
    });

    const closeLightbox = () => {
      lightbox.classList.remove("active");
      document.body.style.overflow = "";
    };

    closeBtn.addEventListener("click", closeLightbox);

    lightbox.addEventListener("click", (e) => {
      if (e.target !== lightboxImg) {
        closeLightbox();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && lightbox.classList.contains("active")) {
        closeLightbox();
      }
    });
  }
</script>
