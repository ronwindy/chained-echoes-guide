---
import "../styles/global.css";
import GuideProgress from "../components/GuideProgress.astro";

interface Section {
  id: string;
  label: string;
}

interface Props {
  title: string;
  subtitle?: string;
  guideId?: string;
  sections?: Section[];
}

const { title, subtitle, guideId, sections } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Ashes of Elrant DLC Interactive Walkthrough"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href=`${baseUrl}favicon.svg` />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Ashes of Elrant DLC Guide</title>
  </head>
  <body class="dlc-theme">
    <div class="layout-container">
      <aside class="sidebar">
        <div class="sidebar-header">
          <button id="menu-toggle" class="menu-toggle" aria-label="Toggle Menu">
            <span class="hamburger"></span>
          </button>
          <a
            href=`${baseUrl}ashes-of-elrant-dlc/table-of-contents`
            class="header-logo"
          >
            <img
              src=`${baseUrl}logo-dlc.png`
              alt="Ashes of Elrant DLC"
              class="sidebar-logo"
            />
          </a>
        </div>
        <nav class="sidebar-nav">
          <details class="nav-section" open>
            <summary><h3>Getting Started</h3></summary>
            <ul class="nav-links">
              <li>
                <a href=`${baseUrl}ashes-of-elrant-dlc/table-of-contents`
                  >Table of Contents</a
                >
              </li>
              <li class="nav-backlink">
                <a href=`${baseUrl}table-of-contents` class="backlink"
                  >↩ Return to Main Guide</a
                >
              </li>
            </ul>
          </details>

          <details class="nav-section">
            <summary><h3>Introduction</h3></summary>
            <ul class="nav-links">
              <li>
                <a
                  href={`${baseUrl}ashes-of-elrant-dlc/ashes-of-elrant-introduction`}
                  >Introduction</a
                >
              </li>
            </ul>
          </details>

          <details class="nav-section">
            <summary><h3>Walkthrough</h3></summary>
            <ul class="nav-links">
              <li>
                <a href={`${baseUrl}ashes-of-elrant-dlc/into-the-unknown`}
                  >Into the Unknown</a
                >
              </li>
              <li>
                <a href={`${baseUrl}ashes-of-elrant-dlc/beyond-the-rift`}
                  >Beyond the Rift</a
                >
              </li>
              <li>
                <a href={`${baseUrl}ashes-of-elrant-dlc/the-big-escape`}
                  >The Big Escape</a
                >
              </li>
              <li>
                <a href={`${baseUrl}ashes-of-elrant-dlc/the-truth-of-elerant`}
                  >The Truth of Elrant</a
                >
              </li>
              <li><a href="#">The Open Way</a></li>
              <li><a href="#">Final World Exploration</a></li>
              <li><a href="#">Deus Ex Machina</a></li>
            </ul>
          </details>

          <details class="nav-section">
            <summary><h3>Sidequest</h3></summary>
            <ul class="nav-links">
              <li><a href="#">A Second Option</a></li>
            </ul>
          </details>

          <details class="nav-section">
            <summary><h3>Reward Board</h3></summary>
            <ul class="nav-links">
              <li><a href="#">Mushroom Forest</a></li>
              <li><a href="#">Elrant City</a></li>
              <li><a href="#">Lost Gardens</a></li>
              <li><a href="#">Deadlands</a></li>
              <li><a href="#">Wastelands</a></li>
              <li><a href="#">Old Town</a></li>
            </ul>
          </details>

          <details class="nav-section">
            <summary><h3>Guides</h3></summary>
            <ul class="nav-links">
              <li><a href="#">All DLC Class Emblems</a></li>
              <li><a href="#">All DLC Collectibles</a></li>
              <li><a href="#">All Flesh of Farnese Locations</a></li>
            </ul>
          </details>
        </nav>
      </aside>

      <div class="content-wrapper">
        <main class="main-content">
          <header class="dlc-header">
            <h1>{title}</h1>
            {subtitle && <p class="subtitle">{subtitle}</p>}
            {
              guideId && (
                <div class="complete-btn-container">
                  <GuideProgress guideId={guideId} guideTitle={title} />
                </div>
              )
            }
          </header>
          <div class="dlc-content">
            <slot />
          </div>
        </main>

        <!-- Right Sidebar Navigation -->
        {
          sections && sections.length > 0 && (
            <aside class="local-toc" id="local-toc">
              <div class="toc-wrapper">
                <h3>Navigation</h3>
                <nav>
                  <ul>
                    {sections.map((section) => (
                      <li>
                        <a href={`#${section.id}`}>{section.label}</a>
                      </li>
                    ))}
                  </ul>
                </nav>
              </div>
            </aside>
          )
        }
      </div>
    </div>
    <div id="sidebar-overlay" class="sidebar-overlay"></div>

    <!-- Image Lightbox Overlay -->
    <div id="image-lightbox" class="lightbox">
      <span class="lightbox-close">&times;</span>
      <img id="lightbox-img" class="lightbox-content" />
    </div>

    <script>
      const menuToggle = document.getElementById("menu-toggle");
      const sidebar = document.querySelector(".sidebar");
      const overlay = document.getElementById("sidebar-overlay");

      if (menuToggle && sidebar && overlay) {
        menuToggle.addEventListener("click", () => {
          sidebar.classList.toggle("active");
          overlay.classList.toggle("active");
          document.body.classList.toggle("menu-open");
        });

        overlay.addEventListener("click", () => {
          sidebar.classList.remove("active");
          overlay.classList.remove("active");
          document.body.classList.remove("menu-open");
        });

        // Close menu when clicking links
        const navLinks = sidebar.querySelectorAll(".nav-links a");
        navLinks.forEach((link) => {
          link.addEventListener("click", () => {
            sidebar.classList.remove("active");
            overlay.classList.remove("active");
            document.body.classList.remove("menu-open");
          });
        });
      }

      // Update sidebar to show completed DLC guides (separate from main game)
      const getCompletedGuides = (): string[] => {
        const stored = localStorage.getItem("chained-echoes-dlc-completed");
        return stored ? JSON.parse(stored) : [];
      };

      const completedGuides = getCompletedGuides();

      // Map DLC guide IDs to their href patterns in the sidebar
      const guideIdMap: Record<string, string> = {
        "dlc-introduction": "ashes-of-elrant-dlc/introduction",
        "dlc-into-the-unknown": "ashes-of-elrant-dlc/into-the-unknown",
        "dlc-beyond-the-rift": "ashes-of-elrant-dlc/beyond-the-rift",
        "dlc-the-big-escape": "ashes-of-elrant-dlc/the-big-escape",
        "dlc-the-truth-of-elrant": "ashes-of-elrant-dlc/the-truth-of-elrant",
        "dlc-the-open-way": "ashes-of-elrant-dlc/the-open-way",
        "dlc-final-world-exploration":
          "ashes-of-elrant-dlc/final-world-exploration",
        "dlc-deus-ex-machina": "ashes-of-elrant-dlc/deus-ex-machina",
        "dlc-a-second-option": "ashes-of-elrant-dlc/a-second-option",
      };

      // Wait for DOM to be ready
      if (typeof document !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
          completedGuides.forEach((guideId) => {
            const hrefPattern = guideIdMap[guideId];
            if (hrefPattern) {
              const link = sidebar?.querySelector(
                `a[href*="${hrefPattern}"]`,
              ) as HTMLAnchorElement;
              if (link) {
                link.classList.add("completed");
              }
            }
          });

          // Highlight active link and open its parent details
          const currentUrlStr = window.location.href
            .split("#")[0]
            .replace(/\/$/, "");
          const allSidebarLinks = document.querySelectorAll(
            ".sidebar .nav-links a",
          );

          allSidebarLinks.forEach((link) => {
            const anchor = link as HTMLAnchorElement;
            const linkUrl = anchor.href.split("#")[0].replace(/\/$/, "");

            if (
              linkUrl === currentUrlStr &&
              link.getAttribute("href") !== "#"
            ) {
              link.classList.add("active");

              let parent = link.parentElement;
              while (parent && !parent.classList.contains("sidebar-nav")) {
                if (parent.tagName === "DETAILS") {
                  (parent as HTMLDetailsElement).open = true;
                }
                parent = parent.parentElement;
              }
            }
          });
        });
      }

      (window as any).updateCompletedIndicators = () => {
        const completedGuides = getCompletedGuides();
        const guideIdMap = {
          "dlc-introduction": "ashes-of-elrant-dlc/introduction",
          "dlc-into-the-unknown": "ashes-of-elrant-dlc/into-the-unknown",
          "dlc-beyond-the-rift": "ashes-of-elrant-dlc/beyond-the-rift",
          "dlc-the-big-escape": "ashes-of-elrant-dlc/the-big-escape",
          "dlc-the-truth-of-elrant": "ashes-of-elrant-dlc/the-truth-of-elrant",
          "dlc-the-open-way": "ashes-of-elrant-dlc/the-open-way",
          "dlc-final-world-exploration":
            "ashes-of-elrant-dlc/final-world-exploration",
          "dlc-deus-ex-machina": "ashes-of-elrant-dlc/deus-ex-machina",
          "dlc-a-second-option": "ashes-of-elrant-dlc/a-second-option",
        };

        const sidebarLinks = document.querySelectorAll(".sidebar .nav-links a");
        sidebarLinks.forEach((link) => {
          const href = link.getAttribute("href") || "";
          const guideId = Object.keys(guideIdMap).find((id) =>
            href.includes((guideIdMap as any)[id]),
          );
          if (guideId && completedGuides.includes(guideId)) {
            link.classList.add("completed");
          } else {
            link.classList.remove("completed");
          }
        });
      };

      // Active link observer for right sidebar
      const observerOptions = {
        root: null,
        rootMargin: "0px 0px -80% 0px",
        threshold: 0,
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute("id");
            const tocLinks = document.querySelectorAll(".local-toc a");
            tocLinks.forEach((link) => {
              const htmlLink = link as HTMLElement;
              htmlLink.classList.remove("active");
              if (htmlLink.getAttribute("href") === `#${id}`) {
                htmlLink.classList.add("active");
                htmlLink.style.color = "var(--accent-gold)";
              } else {
                htmlLink.style.color = "";
              }
            });
          }
        });
      }, observerOptions);

      // Track all sections and quest steps
      const sections = document.querySelectorAll("section[id], article[id]");
      if (sections) {
        sections.forEach((section) => {
          observer.observe(section);
        });
      }

      // Lightbox functionality
      const lightbox = document.getElementById("image-lightbox");
      const lightboxImg = document.getElementById("lightbox-img");
      const closeBtn = document.querySelector(".lightbox-close");

      if (lightbox && lightboxImg && closeBtn) {
        document.querySelectorAll(".main-content img").forEach((img) => {
          const parentLink = img.closest("a");
          if (parentLink) {
            parentLink.addEventListener("click", (e) => e.preventDefault());
          }

          img.addEventListener("click", () => {
            const originalSrc = img.getAttribute("src") || "";
            // Transform the thumbnail URL to the high-res URL
            // Example: https://cdn.staticneo.com/ew/thumb/1/19/Ce_427.jpg/326px-Ce_427.jpg
            // Becomes: https://cdn.staticneo.com/ew/1/19/Ce_427.jpg
            const fullSrc = originalSrc
              .replace("/thumb/", "/")
              .replace(/\/\d+px-[^\/]+$/, "");

            lightboxImg.setAttribute("src", fullSrc);
            lightbox.classList.add("active");
            document.body.style.overflow = "hidden"; // Prevent scrolling
          });
        });

        const closeLightbox = () => {
          lightbox.classList.remove("active");
          document.body.style.overflow = "";
        };

        closeBtn.addEventListener("click", closeLightbox);

        lightbox.addEventListener("click", (e) => {
          if (e.target !== lightboxImg) {
            closeLightbox();
          }
        });

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && lightbox.classList.contains("active")) {
            closeLightbox();
          }
        });
      }
    </script>
  </body>
</html>

<style>
  /* Layout container with sidebars */
  .layout-container {
    display: flex;
    min-height: 100vh;
  }

  .content-wrapper {
    display: flex;
    flex: 1;
    gap: 2rem;
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1rem;
    margin-left: 3rem;
    margin-right: 3rem;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    padding: 2rem 1rem;
    max-width: 1100px;
  }

  /* DLC Header Styling - matches main guide */
  .dlc-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-top: 1rem;
  }

  .dlc-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--accent-gold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    font-family: var(--font-heading);
    font-weight: 700;
  }

  .dlc-header .subtitle {
    color: var(--accent-blue);
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0;
  }

  .complete-btn-container {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
  }

  .dlc-content {
    padding-top: 1rem;
  }

  /* "Return to Main Guide" backlink styling */
  .nav-backlink a.backlink {
    color: var(--text-muted) !important;
    font-style: italic;
    font-size: 0.88rem !important;
    opacity: 0.8;
    transition:
      color 0.2s,
      opacity 0.2s;
  }

  .nav-backlink a.backlink:hover {
    color: var(--accent-gold) !important;
    opacity: 1;
    background-color: transparent !important;
  }

  /* Right Sidebar Navigation */
  .local-toc {
    width: 240px;
    flex-shrink: 0;
  }

  .toc-wrapper {
    position: sticky;
    top: 1.5rem;
    background: linear-gradient(145deg, var(--bg-card), rgba(21, 24, 33, 0.9));
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    max-height: calc(100vh - 3rem);
    overflow-y: auto;
    backdrop-filter: blur(8px);
  }

  .local-toc h3 {
    font-size: 0.95rem;
    color: var(--accent-gold);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .local-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .local-toc li {
    margin-bottom: 0.35rem;
    font-size: 0.88rem;
  }

  .local-toc a {
    color: var(--text-muted);
    text-decoration: none;
    transition:
      color 0.2s,
      padding-left 0.2s;
    display: block;
    line-height: 1.35;
  }

  .local-toc a:hover {
    color: var(--accent-blue);
    padding-left: 5px;
  }

  .local-toc a.active {
    color: var(--accent-gold);
    font-weight: 500;
  }

  /* Responsive Design */
  @media (max-width: 1100px) {
    .content-wrapper {
      gap: 3.5rem;
    }

    .local-toc {
      width: 200px;
    }

    .toc-wrapper {
      padding: 0.85rem 1rem;
    }

    .local-toc h3 {
      font-size: 0.88rem;
    }

    .local-toc li {
      font-size: 0.82rem;
    }
  }

  @media (max-width: 900px) {
    .local-toc {
      display: none;
    }

    .main-content {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .content-wrapper {
      flex-direction: column;
      gap: 0;
      padding: 0;
    }

    .main-content {
      padding: 1.5rem 1rem;
    }
  }

  /* Lightbox Styles */
  .main-content img {
    cursor: zoom-in;
  }

  .lightbox {
    display: none;
    position: fixed;
    z-index: 1000;
    padding-top: 60px;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    background-color: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(5px);
  }

  .lightbox.active {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 0;
  }

  .lightbox-content {
    margin: auto;
    display: block;
    max-width: 90%;
    max-height: 80vh;
    border: 2px solid var(--accent-gold);
    border-radius: 8px;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.8);
    animation: zoom 0.3s ease;
  }

  @keyframes zoom {
    from {
      transform: scale(0.8);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .lightbox-close {
    position: absolute;
    top: 25px;
    right: 35px;
    color: #f1f1f1;
    font-size: 40px;
    font-weight: bold;
    cursor: pointer;
    transition: color 0.2s;
    z-index: 1001;
  }

  .lightbox-close:hover,
  .lightbox-close:focus {
    color: var(--accent-gold);
    text-decoration: none;
  }
</style>
