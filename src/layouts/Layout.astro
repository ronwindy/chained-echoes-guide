                    >Looking for Allies</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/storming-tormund`
                    >Storming Tormund</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/mysterious-girl-2`
                    >Mysterious Girl 2</a
                  >
                </li>
              </ul>
            </details>

            <details class="nav-subsection">
              <summary><h4>Act 3</h4></summary>
              <ul class="nav-links">
                <li>
                  <a href=`${baseUrl}walkthrough/a-call-from-the-past`
                    >A Call From the Past</a
                  >
                </li>
                <li>
                  <a href={`${baseUrl}walkthrough/ruins-under-a-tree`}
                    >Ruins Under a Tree</a
                  >
                </li>
                <li><a href="#">The Grave of Reina</a></li>
                <li><a href="#">In Good Faith</a></li>
              </ul>
            </details>

            <details class="nav-subsection">
              <summary><h4>Finale</h4></summary>
              <ul class="nav-links">
                <li><a href="#">Chained Echoes</a></li>
                <li><a href="#">End of an Era</a></li>
                <li>
                  <a href="#">World Exploration (Finale)</a>
                </li>
                <li><a href="#">Killing Gods</a></li>
              </ul>
            </details>

            <details class="nav-subsection">
              <summary><h4>Post Game</h4></summary>
              <ul class="nav-links">
                <li><a href="#">Eastern Ograne Grottos</a></li>
              </ul>
            </details>
          </details>

          <details class="nav-section">
            <summary><h3>Sidequests</h3></summary>
            <ul class="nav-links">
              <li>
                <a href="#">The Food, the Chap, and the Hungry</a>
              </li>
              <li><a href="#">A Little Vacation</a></li>
              <li><a href="#">The Gates of Nhysa</a></li>
              <li><a href="#">Into the Maelstrom</a></li>
              <li><a href="#">For the Love of Food</a></li>
              <li><a href="#">A Goblin's Dilemma</a></li>
              <li><a href="#">Two-Winged Angel</a></li>
              <li><a href="#">Falfalaran Sings the Fairy</a></li>
              <li><a href="#">A Will To Live</a></li>
              <li><a href="#">No Place for Happy Endings</a></li>
            </ul>
          </details>

          <details class="nav-section">
            <summary><h3>Boss Fights</h3></summary>
            <ul class="nav-links">
              <li><a href="#">Prologue</a></li>
              <li><a href="#">Act 1</a></li>
              <li><a href="#">Act 2</a></li>
              <li><a href="#">Act 3</a></li>
              <li><a href="#">Act 4</a></li>
            </ul>
          </details>

          <details class="nav-section">
            <summary><h3>Reward Board</h3></summary>
            <ul class="nav-links">
              <li><a href="#">Rohlan Fields</a></li>
              <li><a href="#">Dancing City of Farnsport</a></li>
              <li><a href="#">Ograne Grottos</a></li>
              <li><a href="#">Kortara Mountain Range</a></li>
              <li><a href="#">Fiorwoods</a></li>
              <li><a href="#">City of Rain Tormund</a></li>
              <li><a href="#">Flower Fields of Perpetua</a></li>
              <li><a href="#">Arkant Archipelago</a></li>
              <li><a href="#">New Wyrnshire</a></li>
              <li><a href="#">Flying Continent Shambala</a></li>
