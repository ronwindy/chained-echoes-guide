---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Chained Echoes Interactive Walkthrough" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href=`${baseUrl}favicon.svg` />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Chained Echoes Guide</title>
  </head>
  <body>
    <div class="layout-container">
      <aside class="sidebar">
        <div class="sidebar-header">
          <button id="menu-toggle" class="menu-toggle" aria-label="Toggle Menu">
            <span class="hamburger"></span>
          </button>
          <a href=`${baseUrl}table-of-contents` class="header-logo">
            <img
              src=`${baseUrl}logo.png`
              alt="Chained Echoes"
              class="sidebar-logo"
            />
          </a>
        </div>
        <nav class="sidebar-nav">
          <details class="nav-section">
            <summary><h3>Getting Started</h3></summary>
            <ul class="nav-links">
              <li><a href={baseUrl}>Introduction</a></li>
              <li>
                <a href=`${baseUrl}table-of-contents`>Table of Contents</a>
              </li>
            </ul>
          </details>

          <details class="nav-section">
            <summary><h3>Walkthrough</h3></summary>
            <details class="nav-subsection">
              <summary><h4>Act 2</h4></summary>
              <ul class="nav-links">
                <li>
                  <a href=`${baseUrl}walkthrough/three-months-later`
                    >Three Months Later</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/world-exploration`
                    >World Exploration</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/search-for-princess`
                    >Searching for a Princess</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/looking-for-allies`
                    >Looking for Allies</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/storming-tormund`
                    >Storming Tormund</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/mysterious-girl-2`
                    >Mysterious Girl 2</a
                  >
                </li>
              </ul>
            </details>

            <details class="nav-subsection">
              <summary><h4>Act 3</h4></summary>
              <ul class="nav-links">
                <li>
                  <a href=`${baseUrl}walkthrough/a-call-from-the-past`
                    >A Call From the Past</a
                  >
                </li>
                <li>
                  <a href={`${baseUrl}walkthrough/ruins-under-a-tree`}
                    >Ruins Under a Tree</a
                  >
                </li>
                <li>
                  <a href={`${baseUrl}walkthrough/grave-of-reina`}
                    >The Grave of Reina</a
                  >
                </li>
                <li>
                  <a href={`${baseUrl}walkthrough/in-good-faith`}
                    >In Good Faith</a
                  >
                </li>
              </ul>
            </details>

            <details class="nav-subsection">
              <summary><h4>Finale</h4></summary>
              <ul class="nav-links">
                <li>
                  <a href=`${baseUrl}walkthrough/chained-echoes`
                    >Chained Echoes</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/end-of-an-era`>End of an Era</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/world-exploration-2`
                    >World Exploration (2nd)</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/killing-gods`>Killing Gods</a>
                </li>
              </ul>
            </details>

            <details class="nav-subsection">
              <summary><h4>Post Game</h4></summary>
              <ul class="nav-links">
                <li>
                  <a href=`${baseUrl}walkthrough/eastern-ograne-grottos`
                    >Eastern Ograne Grottos</a>
                </li>
              </ul>
            </details>
          </details>

          <details class="nav-section">
            <summary><h3>Sidequests</h3></summary>
            <ul class="nav-links">
              <li>
                <a href=`${baseUrl}sidequests/the-food-the-chap-and-the-hungry`
                  >The Food, the Chap, and the Hungry</a
                >
              </li>
              <li>
                <a href=`${baseUrl}sidequests/a-little-vacation`
                  >A Little Vacation</a>
              </li>
              <li>
                <a href=`${baseUrl}sidequests/the-gates-of-nhysa`
                  >The Gates of Nhysa</a>
              </li>
              <li>
                <a href=`${baseUrl}sidequests/into-the-maelstrom`
                  >Into the Maelstrom</a>
              </li>
              <li>
                <a href=`${baseUrl}sidequests/for-the-love-of-food`
                  >For the Love of Food</a>
              </li>
              <li>
                <a href=`${baseUrl}sidequests/a-goblins-dilemma`
                  >A Goblin's Dilemma</a>
              </li>
              <li>
                <a href=`${baseUrl}sidequests/two-winged-angel`
                  >Two-Winged Angel</a>
              </li>
              <li>
                <a href=`${baseUrl}sidequests/falfalaran-sings-the-fairy`
                  >Falfalaran Sings the Fairy</a>
              </li>
              <li>
                <a href=`${baseUrl}sidequests/a-will-to-live`>A Will To Live</a>
              </li>
              <li>
                <a href=`${baseUrl}sidequests/no-place-for-happy-endings`
                  >No Place for Happy Endings</a>
              </li>
            </ul>
          </details>

          <div class="nav-dlc-callout">
            <a
              href=`${baseUrl}ashes-of-elrant-dlc/table-of-contents`
              class="dlc-callout-link"
            >
              <span class="dlc-callout-icon">⚡</span>
              <span>Ashes of Elrant DLC</span>
              <span class="dlc-callout-arrow">→</span>
            </a>
          </div>
        </nav>
      </aside>
      <main class="main-content">
        <slot />
      </main>
    </div>
    <div id="sidebar-overlay" class="sidebar-overlay"></div>

    <script>
      const menuToggle = document.getElementById("menu-toggle");
      const sidebar = document.querySelector(".sidebar");
      const overlay = document.getElementById("sidebar-overlay");

      if (menuToggle && sidebar && overlay) {
        menuToggle.addEventListener("click", () => {
          sidebar.classList.toggle("active");
          overlay.classList.toggle("active");
          document.body.classList.toggle("menu-open");
        });

        overlay.addEventListener("click", () => {
          sidebar.classList.remove("active");
          overlay.classList.remove("active");
          document.body.classList.remove("menu-open");
        });

        // Close menu when clicking links
        const navLinks = sidebar.querySelectorAll(".nav-links a");
        navLinks.forEach((link) => {
          link.addEventListener("click", () => {
            sidebar.classList.remove("active");
            overlay.classList.remove("active");
            document.body.classList.remove("menu-open");
          });
        });
      }

      // Update sidebar to show completed guides
      const getCompletedGuides = (): string[] => {
        const stored = localStorage.getItem("chained-echoes-completed");
        return stored ? JSON.parse(stored) : [];
      };

      const completedGuides = getCompletedGuides();

      // Map guide IDs to their href patterns in the sidebar
      const guideIdMap: Record<string, string> = {
        "three-months-later": "walkthrough/three-months-later",
        "world-exploration": "walkthrough/world-exploration",
        "search-for-princess": "walkthrough/search-for-princess",
        "looking-for-allies": "walkthrough/looking-for-allies",
        "storming-tormund": "walkthrough/storming-tormund",
        "mysterious-girl-2": "walkthrough/mysterious-girl-2",
        "world-exploration-2": "walkthrough/world-exploration-2",
        "a-call-from-the-past": "walkthrough/a-call-from-the-past",
        "ruins-under-a-tree": "walkthrough/ruins-under-a-tree",
        "killing-gods": "walkthrough/killing-gods",
        "eastern-ograne-grottos": "walkthrough/eastern-ograne-grottos",
        "the-food-the-chap-and-the-hungry":
          "sidequests/the-food-the-chap-and-the-hungry",
        "a-little-vacation": "sidequests/a-little-vacation",
        "the-gates-of-nhysa": "sidequests/the-gates-of-nhysa",
        "into-the-maelstrom": "sidequests/into-the-maelstrom",
        "for-the-love-of-food": "sidequests/for-the-love-of-food",
        "a-goblins-dilemma": "sidequests/a-goblins-dilemma",
        "two-winged-angel": "sidequests/two-winged-angel",
        "falfalaran-sings-the-fairy": "sidequests/falfalaran-sings-the-fairy",
        "a-will-to-live": "sidequests/a-will-to-live",
        "no-place-for-happy-endings": "sidequests/no-place-for-happy-endings",
      };

      // Wait for DOM to be ready
      if (typeof document !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
          completedGuides.forEach((guideId) => {
            const hrefPattern = guideIdMap[guideId];
            if (hrefPattern) {
              const link = sidebar?.querySelector(
                `a[href*="${hrefPattern}"]`,
              ) as HTMLAnchorElement;
              if (link) {
                link.classList.add("completed");
              }
            }
          });

          // Highlight active link and open its parent details
          const currentUrlStr = window.location.href
            .split("#")[0]
            .replace(/\/$/, "");
          const allSidebarLinks = document.querySelectorAll(
            ".sidebar .nav-links a",
          );

          allSidebarLinks.forEach((link) => {
            const anchor = link as HTMLAnchorElement;
            const linkUrl = anchor.href.split("#")[0].replace(/\/$/, "");

            // Check if link matches current URL and is not a placeholder
            if (
              linkUrl === currentUrlStr &&
              link.getAttribute("href") !== "#"
            ) {
              link.classList.add("active");

              // Traverse up and open all parent <details> elements
              let parent = link.parentElement;
              while (parent && !parent.classList.contains("sidebar-nav")) {
                if (parent.tagName === "DETAILS") {
                  (parent as HTMLDetailsElement).open = true;
                }
                parent = parent.parentElement;
              }
            }
          });
        });
      }

      (window as any).updateCompletedIndicators = () => {
        const completedGuides = getCompletedGuides();
        const guideIdMap = {
          "three-months-later": "walkthrough/three-months-later",
          "world-exploration": "walkthrough/world-exploration",
          "search-for-princess": "walkthrough/search-for-princess",
          "looking-for-allies": "walkthrough/looking-for-allies",
          "storming-tormund": "walkthrough/storming-tormund",
          "mysterious-girl-2": "walkthrough/mysterious-girl-2",
          "world-exploration-2": "walkthrough/world-exploration-2",
          "a-call-from-the-past": "walkthrough/a-call-from-the-past",
          "ruins-under-a-tree": "walkthrough/ruins-under-a-tree",
          "killing-gods": "walkthrough/killing-gods",
          "eastern-ograne-grottos": "walkthrough/eastern-ograne-grottos",
          "the-food-the-chap-and-the-hungry":
            "sidequests/the-food-the-chap-and-the-hungry",
          "a-little-vacation": "sidequests/a-little-vacation",
          "the-gates-of-nhysa": "sidequests/the-gates-of-nhysa",
          "into-the-maelstrom": "sidequests/into-the-maelstrom",
          "for-the-love-of-food": "sidequests/for-the-love-of-food",
          "a-goblins-dilemma": "sidequests/a-goblins-dilemma",
          "two-winged-angel": "sidequests/two-winged-angel",
          "falfalaran-sings-the-fairy": "sidequests/falfalaran-sings-the-fairy",
          "a-will-to-live": "sidequests/a-will-to-live",
          "no-place-for-happy-endings": "sidequests/no-place-for-happy-endings",
        };

        const sidebarLinks = document.querySelectorAll(".sidebar .nav-links a");
        sidebarLinks.forEach((link) => {
          const href = link.getAttribute("href") || "";
          const guideId = Object.keys(guideIdMap).find((id) =>
            href.includes(id),
          );
          if (guideId && completedGuides.includes(guideId)) {
            link.classList.add("completed");
          } else {
            link.classList.remove("completed");
          }
        });
      };
    </script>
  </body>
</html>
