---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Chained Echoes Interactive Walkthrough" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href=`${baseUrl}favicon.svg` />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Chained Echoes Guide</title>
  </head>
  <body>
    <div class="layout-container">
      <aside class="sidebar">
        <div class="sidebar-header">
          <button id="menu-toggle" class="menu-toggle" aria-label="Toggle Menu">
            <span class="hamburger"></span>
          </button>
          <a href=`${baseUrl}table-of-contents` class="header-logo">
            <img
              src=`${baseUrl}logo.png`
              alt="Chained Echoes"
              class="sidebar-logo"
            />
          </a>
        </div>
        <nav class="sidebar-nav">
          <details class="nav-section" open>
            <summary><h3>Getting Started</h3></summary>
            <ul class="nav-links">
              <li><a href={baseUrl}>Controls</a></li>
              <li>
                <a href=`${baseUrl}table-of-contents`>Table of Contents</a>
              </li>
            </ul>
          </details>

          <details class="nav-section">
            <summary><h3>Walkthrough</h3></summary>
            <details class="nav-subsection" open>
              <summary><h4>Act 2</h4></summary>
              <ul class="nav-links">
                <li>
                  <a href=`${baseUrl}walkthrough/three-months-later`
                    >Three Months Later</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/world-exploration`
                    >World Exploration</a
                  >
                </li>
                <li>
                  <a href=`${baseUrl}walkthrough/search-for-princess`
                    >Searching for a Princess</a
                  >
                </li>
                <li>
