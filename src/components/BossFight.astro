---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="boss-fight-card">
  <h4 class="boss-title">{title}</h4>
  
  <div class="boss-content">
    <slot />
  </div>
</div>

<style>
  .boss-fight-card {
    background: rgba(200, 50, 50, 0.05);
    border: 1px solid rgba(200, 50, 50, 0.2);
    border-radius: 12px;
    padding: 2.5rem;
    margin: 4rem 0;
    position: relative;
    overflow: hidden;
  }

  .boss-fight-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, transparent, #ff6b6b, transparent);
  }

  .boss-title {
    color: #ff6b6b;
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 2rem;
    text-shadow: 0 0 15px rgba(255, 107, 107, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .boss-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.boss-stats) {
    margin-top: 1rem;
    background: rgba(0, 0, 0, 0.4);
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid rgba(255, 107, 107, 0.1);
  }

  :global(.boss-stats h5) {
    color: var(--accent-gold);
    margin-bottom: 1rem;
    font-size: 1.1rem;
    text-transform: uppercase;
  }

  :global(.boss-stats ul) {
    list-style: none;
    padding: 0;
  }

  :global(.boss-stats li) {
    margin-bottom: 0.75rem;
    padding-left: 1.5rem;
    position: relative;
    color: #e0e0e0;
  }

  :global(.boss-stats li::before) {
    content: "◈";
    position: absolute;
    left: 0;
    color: #ff6b6b;
  }
</style>
